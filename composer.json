{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "graid/social-network",
    "type": "project",
    "description": "Грейдирование HTML_ACADEMY",
    "keywords": ["laravel", "HTML_ACADEMY"],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^13.0",
        "laravel/sanctum": "^4.3",
        "laravel/tinker": "^3.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "laravel/sail": "^1.56",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^12.5.12",
        "squizlabs/php_codesniffer": "^3.10",
        "vimeo/psalm": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "./vendor/bin/sail up -d",
            "./vendor/bin/sail artisan key:generate --ansi",
            "./vendor/bin/sail artisan migrate --force --ansi",
            "./vendor/bin/sail artisan db:seed --force --ansi",
            "./vendor/bin/sail artisan optimize:clear --ansi",
            "./vendor/bin/sail artisan storage:link --force --ansi",
            "./vendor/bin/sail npm install --ignore-scripts",
            "./vendor/bin/sail npm run build"
        ],
        "dev": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "./vendor/bin/sail up -d",
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185\" \"./vendor/bin/sail artisan queue:listen --tries=1 --timeout=0\" \"./vendor/bin/sail artisan pail --timeout=0\" \"./vendor/bin/sail npm run dev\" --names=queue,logs,vite --kill-others"
        ],
        "test": [
            "./vendor/bin/sail up -d",
            "./vendor/bin/sail artisan config:clear --ansi",
            "./vendor/bin/sail artisan test"
        ],
        "phpcs": [
            "./vendor/bin/sail up -d",
            "./vendor/bin/sail php vendor/bin/phpcs"
        ],
        "psalm": [
            "./vendor/bin/sail up -d",
            "./vendor/bin/sail php vendor/bin/psalm --no-progress"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
